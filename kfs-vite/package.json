{
  "name": "js-kfs",
  "description": "A lightweight, fast, and efficient pure JavaScript library for managing files and directories in a browser.",
  "author": "Kani",
  "license": "MIT",
  "version": "0.2.6",
  "type": "module",
  "main": "./kfs/kfs.js",
  "module": "./kfs/kfs.js",
  "exports": {
    ".": {
      "import": "./kfs/kfs.js",
      "default": "./kfs/kfs.js"
    },
    "./kfs/*": {
      "import": "./kfs/*",
      "default": "./kfs/*"
    },
    "./assets/*": {
      "import": "./kfs/assets/*",
      "default": "./kfs/assets/*"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "filesystem",
    "git",
    "browser",
    "kfs",
    "virtual-filesystem",
    "isomorphic-git"
  ],
  "dependencies": {
    "@isomorphic-git/lightning-fs": "^4.6.0",
    "buffer": "^6.0.3",
    "isomorphic-git": "^1.30.1",
    "process": "^0.11.10"
  },
  "devDependencies": {
    "vite": "^6.3.1",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-node-polyfills": "^0.2.0"
  },
  "files": [
    "kfs",
    "README.md",
    "LICENSE"
  ]
}
