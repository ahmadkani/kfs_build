{
  "corsProxy": "http://localhost:9999",
  "dir": "/",
  "logging": {
    "vfs": true,
    "kfs": true,
    "IDBFs": true,
    "gitWorker": true,
    "acl": true,
    "stats": true,
    "fsType": true,
    "fsManagerES6": true,
    "fsManagerGlobal": true,
    "swUtils": true,
    "memoryFS": true,
    "memoryBackendES6": true,
    "memoryBackendGlobal": true,
    "VFSutils": true,
    "gitNoteManager": true,
    "ServiceWorkerRegistration": true,
    "serviceWorker": true,
    "storageUtils": true,
    "supportChecker": true,
